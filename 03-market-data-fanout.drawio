<mxfile host="app.diagrams.net" agent="architecture-homework" version="24.0.0">
  <diagram id="market-data-fanout" name="Market data fan-out">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1150" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="provider" value="Market data provider&#xa;&lt;font style=&quot;font-size:10px&quot;&gt;FIX / FAST / WebSocket&#xa;paid, licensed per end user&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="30" y="180" width="170" height="80" as="geometry" />
        </mxCell>

        <mxCell id="mds" value="Market data service&#xa;&lt;font style=&quot;font-size:10px&quot;&gt;ACL: normalise ticks&#xa;conflation ~300 ms&#xa;onBackpressureLatest&#xa;last-value cache (Caffeine)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="270" y="170" width="190" height="100" as="geometry" />
        </mxCell>

        <mxCell id="topic" value="Compacted topic&#xa;&lt;font style=&quot;font-size:10px&quot;&gt;keyed by ISIN&#xa;(Kafka / Redis pub-sub)&#xa;new instance rebuilds state&#xa;without touching upstream&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="530" y="170" width="170" height="100" as="geometry" />
        </mxCell>

        <mxCell id="gw1" value="Gateway instance 1&#xa;&lt;font style=&quot;font-size:10px&quot;&gt;WebFlux, ~10k sockets&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="770" y="100" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="gw2" value="Gateway instance 2&#xa;&lt;font style=&quot;font-size:10px&quot;&gt;WebFlux, ~10k sockets&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="770" y="190" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="gw3" value="Gateway instance N&#xa;&lt;font style=&quot;font-size:10px&quot;&gt;WebFlux, ~10k sockets&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="770" y="280" width="160" height="60" as="geometry" />
        </mxCell>

        <mxCell id="clients" value="Clients&#xa;&lt;font style=&quot;font-size:10px&quot;&gt;app / internet bank&#xa;thousands concurrent&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="990" y="180" width="120" height="80" as="geometry" />
        </mxCell>

        <mxCell id="ep" value="subscribe — one per instrument, never per user" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d79b00;strokeWidth=2;endArrow=block;fontSize=10;" edge="1" parent="1" source="provider" target="mds"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="et" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#9673a6;strokeWidth=2;endArrow=block;" edge="1" parent="1" source="mds" target="topic"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eg1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82b366;strokeWidth=2;endArrow=block;" edge="1" parent="1" source="topic" target="gw1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eg2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82b366;strokeWidth=2;endArrow=block;" edge="1" parent="1" source="topic" target="gw2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eg3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82b366;strokeWidth=2;endArrow=block;" edge="1" parent="1" source="topic" target="gw3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec1" value="WebSocket" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#666666;endArrow=block;fontSize=10;" edge="1" parent="1" source="gw1" target="clients"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#666666;endArrow=block;" edge="1" parent="1" source="gw2" target="clients"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#666666;endArrow=block;" edge="1" parent="1" source="gw3" target="clients"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="note1" value="&lt;b&gt;The invariant that makes this scale&lt;/b&gt;&#xa;Upstream subscriptions scale with the instrument catalogue, not with the user count.&#xa;10 000 users cost the same upstream as 10. Getting this wrong is a licensing bill, not a latency bug.&#xa;Users without a real-time entitlement are served the delayed topic through the identical pipeline." style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="30" y="400" width="640" height="90" as="geometry" />
        </mxCell>
        <mxCell id="note2" value="&lt;b&gt;Not durable, not authoritative&lt;/b&gt;&#xa;A dropped tick is replaced by the next one — no delivery guarantee needed.&#xa;The displayed price is indicative and is never used for execution or regulatory reporting.&#xa;On connect: snapshot from the last-value cache, then the delta stream." style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="700" y="400" width="410" height="90" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
